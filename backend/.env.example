# Copy to `.env` and fill in. With NOTHING set, Katha runs fully offline (mock provider,
# in-memory stores) — the demo and self-tests need none of these.

# --- LLM provider: "mock" (default, offline) | "ollama" (free local) | "gemini" (cloud) ---
KATHA_LLM_PROVIDER=mock
# Ollama (local, free — no key). Run `ollama serve` + `ollama pull hermes3`.
OLLAMA_URL=http://localhost:11434
KATHA_OLLAMA_MODEL=hermes3
# Gemini (cloud, paid)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# --- Voice / TTS (Sarvam Bulbul). With NO key, the web client uses the browser's
#     built-in speech for free. Set a key for production Indian voices. ---
SARVAM_API_KEY=
SARVAM_MODEL=bulbul:v3
# SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech   # override only if needed
KATHA_VOICE=0

# --- Vector store: "memory" (default) | "chroma" | "pinecone" ---
KATHA_VECTOR_STORE=memory
# Retrieval mode for the in-memory store:
#   "lexical" (token overlap, offline, default) | "ollama" (real semantic, free local)
# For "ollama": run `ollama pull nomic-embed-text` first.
KATHA_EMBEDDINGS=lexical
KATHA_OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Database (empty = in-memory). Example: sqlite:///katha.db ---
DATABASE_URL=

# --- Analytics / durable player telemetry ---
# Backend is auto-selected: Supabase if both vars below are set (durable, survives
# Hugging Face restarts); else local SQLite if KATHA_ANALYTICS_DB is set; else no-op.
# Get these from your Supabase project -> Settings -> API:
#   SUPABASE_URL         = Project URL      (e.g. https://xxxxxxxx.supabase.co)
#   SUPABASE_SERVICE_KEY = service_role key (SECRET — server-side only, never in the client)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Local-only capture instead of Supabase (dev/offline). Ignored when Supabase is set.
# KATHA_ANALYTICS_DB=katha_analytics.db
# Set to 0 to disable all telemetry.
KATHA_ANALYTICS=1
