{
  "expo": {
    "name": "Katha",
    "slug": "katha",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#05060f",
    "splash": { "backgroundColor": "#05060f", "resizeMode": "contain" },
